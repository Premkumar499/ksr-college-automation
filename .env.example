# Application Settings
APP_NAME="Scholarship AI System"
VERSION="1.0.0"

# PostgreSQL Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scholarship_db"

# Heavy Server URL (GPU Server)
HEAVY_SERVER_URL="http://localhost:8001"

# Gemini API Key (Get from https://makersuite.google.com/app/apikey)
GOOGLE_API_KEY=""

# HuggingFace API Key (optional, for embeddings)
HUGGINGFACE_API_KEY=""

# FAISS DB Paths (local vector storage - not a database)
FAISS_DB_PATH="./data/embeddings/faiss_db"
FAISS_HF_DB_PATH="./data/embeddings/faiss_db_hf"
FAISS_GEMINI_DB_PATH="./data/embeddings/faiss_db_gemini"

# Server Configuration
NORMAL_SERVER_HOST="0.0.0.0"
NORMAL_SERVER_PORT=8000
HEAVY_SERVER_HOST="0.0.0.0"
HEAVY_SERVER_PORT=8001

# Security
SECRET_KEY="your-secret-key-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
